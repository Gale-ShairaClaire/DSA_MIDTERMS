<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Manager" Height="520" Width="800">
    <StackPanel Orientation="Vertical" Margin="10" RenderTransformOrigin="0.5,0.5">

        <TextBlock Text="Available Items" HorizontalAlignment="Center" FontSize="24" Margin="0,0,0,10"/>
        <StackPanel Orientation="Vertical"/>
        <DataGrid x:Name="myDataGrid"
                  ItemsSource="{Binding Students}"
                  AutoGenerateColumns="False"
                  Height="151"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="myDataGrid_SelectionChanged" Width="782" RenderTransformOrigin="-0.24,0.409">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product ID"         Binding="{Binding ProductID}"         Width="*"/>
                <DataGridTextColumn Header="Product Name"       Binding="{Binding ProductName}"       Width="*"/>
                <DataGridTextColumn Header="Description"      Binding="{Binding Description}"      Width="*"/>
                <DataGridTextColumn Header="Price"     Binding="{Binding Price}"     Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Text="Shopping Cart" HorizontalAlignment="Center" FontSize="24" Margin="0,0,0,10"/>
        <StackPanel Orientation="Vertical"/>
        <DataGrid x:Name="DataGrid"
          ItemsSource="{Binding Students}"
          AutoGenerateColumns="False"
          Height="156"
          IsReadOnly="True"
          SelectionMode="Single"
          SelectionChanged="myDataGrid_SelectionChanged" Width="782" RenderTransformOrigin="-0.24,0.409">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product ID"         Binding="{Binding ProductID}"         Width="*"/>
                <DataGridTextColumn Header="Product Name"       Binding="{Binding ProductName}"       Width="*"/>
                <DataGridTextColumn Header="Description"      Binding="{Binding Description}"      Width="*"/>
                <DataGridTextColumn Header="Price"     Binding="{Binding Price}"     Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- DataGrid -->

        <!-- Input Fields with labels above -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ID -->
            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Text="Product ID:" Margin="0,0,0,2"/>
                <TextBox x:Name="txtID" Height="26"/>
            </StackPanel>

            <!-- Name -->
            <StackPanel Grid.Column="1" Margin="0,0,6,0">
                <TextBlock Text="Product Name:" Margin="0,0,0,2"/>
                <TextBox x:Name="txtName" Height="26"/>
            </StackPanel>

            <!-- Title -->
            <StackPanel Grid.Column="2" Margin="0,0,6,0">
                <TextBlock Text="Description:" Margin="0,0,0,2"/>
                <TextBox x:Name="txtTitle" Height="26"/>
            </StackPanel>

            <!-- Salary -->
            <StackPanel Grid.Column="3" Margin="0,0,0,0">
                <TextBlock Text="Price:" Margin="0,0,0,2"/>
                <TextBox x:Name="txtSalary" Height="26"/>
            </StackPanel>

        </Grid>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Add Item"    Width="80" Margin="4,0" Click="AddButton_Click"/>
            <Button Content="Remove" Width="80" Margin="4,0" Click="Button_Click"/>
            <Button Content="Add to Cart" Width="80" Margin="4,0" Clissck="UpdateButton_Click"/>
            <Button Content="Clear"  Width="80" Margin="4,0" Click="ClearButton_Click"/>
        </StackPanel>

    </StackPanel>
</Window>